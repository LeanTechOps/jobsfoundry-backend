generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id            String           @id @default(uuid())
  email         String           @unique @db.VarChar(255)
  firstName     String?          @db.VarChar(255)
  lastName      String?          @db.VarChar(255)
  avatar        String?
  role          UserRole         @default(MEMBER)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  authProviders AuthProvider[]
  subscription  Subscription?
  profile       Profile?
  postedJobs    Job[]
}

// ============================================
// PROFILE
// ============================================

model Profile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  headline     String?  @db.VarChar(255)
  bio          String?  @db.Text
  location     String?  @db.VarChar(255)
  phoneNumber  String?  @db.VarChar(50)

  linkedinUrl  String?  @db.VarChar(500)
  githubUrl    String?  @db.VarChar(500)
  portfolioUrl String?  @db.VarChar(500)

  // Address
  address      String?  @db.VarChar(500)
  city         String?  @db.VarChar(100)
  state        String?  @db.VarChar(100)
  country      String?  @db.VarChar(100)
  zipCode      String?  @db.VarChar(20)

  // Work authorisation
  visaType     VisaType?

  // Skills — stored as a simple array for filtering
  skills       String[]

  resumes      Resume[]
  applications JobApplication[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Resume {
  id           String           @id @default(uuid())
  profileId    String
  profile      Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  key          String           @db.VarChar(500)
  thumbnailKey String?          @db.VarChar(500)
  originalName String           @db.VarChar(255)
  label        String?          @db.VarChar(100)
  contentType  String           @db.VarChar(100)
  isDefault    Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  applications JobApplication[]

  @@index([profileId])
}


model AuthProvider {
  id           String       @id @default(uuid())
  userId       String
  provider     ProviderEnum
  providerId   String
  accessToken  String?      @db.Text
  refreshToken String?      @db.Text
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
}

// ============================================
// SUBSCRIPTION SYSTEM
// ============================================

model Subscription {
  id                   String              @id @default(uuid())
  userId               String              @unique
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?             @unique
  stripeSubscriptionId String?             @unique
  status               SubscriptionStatus  @default(ACTIVE)
  plan                 SubscriptionPlan    @default(FORGE)
  billingCycle         BillingCycle        @default(MONTHLY)
  subscriptionStartedAt DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAt             DateTime?
  cancelAtPeriodEnd    Boolean             @default(false)
  currentPrice         Decimal?            @db.Decimal(10, 2)
  currency             String              @default("usd") @db.VarChar(3)
  metadata             Json?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  invoices             Invoice[]
  payments             Payment[]
  subscriptionHistory  SubscriptionHistory[]

  @@index([status])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model SubscriptionHistory {
  id             String                @id @default(uuid())
  subscriptionId String
  subscription   Subscription          @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  eventType      SubscriptionEventType
  oldStatus      SubscriptionStatus?
  newStatus      SubscriptionStatus?
  oldPlan        SubscriptionPlan?
  newPlan        SubscriptionPlan?
  description    String?               @db.Text
  metadata       Json?
  createdAt      DateTime              @default(now())

  @@index([subscriptionId])
  @@index([eventType])
  @@index([createdAt])
}

model Invoice {
  id                String        @id @default(uuid())
  subscriptionId    String
  subscription      Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  stripeInvoiceId   String        @unique
  stripeHostedUrl   String?       @db.Text
  stripePdfUrl      String?       @db.Text
  status            InvoiceStatus @default(DRAFT)
  amountDue         Decimal       @db.Decimal(10, 2)
  amountPaid        Decimal       @default(0) @db.Decimal(10, 2)
  amountRemaining   Decimal       @db.Decimal(10, 2)
  currency          String        @default("usd") @db.VarChar(3)
  invoiceDate       DateTime
  dueDate           DateTime?
  paidAt            DateTime?
  periodStart       DateTime?
  periodEnd         DateTime?
  description       String?       @db.Text
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  payments          Payment[]

  @@index([subscriptionId])
  @@index([stripeInvoiceId])
  @@index([status])
  @@index([invoiceDate])
}

model Payment {
  id                    String        @id @default(uuid())
  subscriptionId        String
  subscription          Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoiceId             String?
  invoice               Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  stripePaymentIntentId String?       @unique
  stripeChargeId        String?       @unique
  status                PaymentStatus @default(PENDING)
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("usd") @db.VarChar(3)
  paymentMethod         String?       @db.VarChar(50)
  cardBrand             String?       @db.VarChar(50)
  cardLast4             String?       @db.VarChar(4)
  cardExpMonth          Int?
  cardExpYear           Int?
  failureReason         String?       @db.Text
  failureCode           String?       @db.VarChar(100)
  retriedCount          Int           @default(0)
  paidAt                DateTime?
  failedAt              DateTime?
  metadata              Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([subscriptionId])
  @@index([invoiceId])
  @@index([status])
  @@index([createdAt])
}

model StripeWebhookEvent {
  id              String    @id @default(uuid())
  stripeEventId   String    @unique
  eventType       String    @db.VarChar(255)
  apiVersion      String?   @db.VarChar(50)
  data            Json
  processed       Boolean   @default(false)
  processedAt     DateTime?
  processingError String?   @db.Text
  retryCount      Int       @default(0)
  createdAt       DateTime  @default(now())

  @@index([stripeEventId])
  @@index([processed])
  @@index([eventType])
  @@index([createdAt])
}

// ============================================
// JOBS
// ============================================

model Job {
  id                 String          @id @default(uuid())
  title              String          @db.VarChar(255)
  company            String          @db.VarChar(255)
  companyDomain      String?         @db.VarChar(255)
  location           String?         @db.VarChar(255)
  workMode           WorkMode        @default(ONSITE)
  type               JobType         @default(FULL_TIME)
  experienceLevel    ExperienceLevel @default(MID)
  status             JobStatus       @default(DRAFT)

  description        String          @db.Text
  responsibilities   String?         @db.Text
  requirements       String?         @db.Text
  benefits           String?         @db.Text

  skills             String[]

  salaryMin          Decimal?        @db.Decimal(12, 2)
  salaryMax          Decimal?        @db.Decimal(12, 2)
  salaryCurrency     String          @default("USD") @db.VarChar(3)
  salaryPeriod       SalaryPeriod    @default(MONTHLY)
  salaryNegotiable   Boolean         @default(false)

  visaSponsorship    Boolean         @default(false)

  applicationUrl     String?         @db.VarChar(500)

  companyLogoKey     String?         @db.VarChar(500)

  postedById         String?
  postedBy           User?           @relation(fields: [postedById], references: [id], onDelete: SetNull)
  applications       JobApplication[]

  closesAt           DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([status])
  @@index([type])
  @@index([experienceLevel])
  @@index([createdAt])
}

// ============================================
// JOB APPLICATIONS
// ============================================

model JobApplication {
  id          String            @id @default(uuid())
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId       String
  profile     Profile           @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId   String
  resume      Resume?           @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  resumeId    String?
  status      ApplicationStatus @default(APPLIED)
  interviewAt DateTime?
  notes       String?           @db.Text
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([jobId, profileId])
  @@index([profileId])
  @@index([jobId])
  @@index([status])
}

// ============================================
// ENUMS
// ============================================

enum ProviderEnum {
  GOOGLE
}

enum UserRole {
  MEMBER
  MANAGER
  RECRUITER
  ADMIN
}

enum VisaType {
  US_CITIZEN
  GREEN_CARD
  H1B
  H4_EAD
  L1
  O1
  TN
  F1_OPT
  F1_CPT
  EAD
  OTHER
}

enum WorkMode {
  ONSITE
  REMOTE
  HYBRID
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  LEAD
  EXECUTIVE
}

enum JobStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
}

enum ApplicationStatus {
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

enum SalaryPeriod {
  HOURLY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  PAUSED
  UNPAID
}

enum SubscriptionPlan {
  FORGE
  FORGE_FREE
  CRAFT
  LAUNCH
  MOMENTUM
}

enum BillingCycle {
  MONTHLY
  YEARLY
  QUARTERLY
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum SubscriptionEventType {
  SUBSCRIBED
  PLAN_UPGRADED
  PLAN_DOWNGRADED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  PAYMENT_REFUNDED
  SUBSCRIPTION_RENEWED
  SUBSCRIPTION_CANCELED
  SUBSCRIPTION_REACTIVATED
  SUBSCRIPTION_PAUSED
  SUBSCRIPTION_RESUMED
}
