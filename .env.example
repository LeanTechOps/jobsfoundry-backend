# Database
DATABASE_URL=postgresql://jobblitz:jobblitz@localhost:5432/jobblitz
DIRECT_URL=postgresql://jobblitz:jobblitz@localhost:5432/jobblitz

# Server
PORT=3000
NODE_ENV=development

# Frontend
FRONTEND_URL=http://localhost:4000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/redirect

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRY=7d

# Redis (use redis://localhost:6379 for local dev, redis://redis:6379 inside Docker)
REDIS_URL=redis://localhost:6379

# Stripe — plans are fetched live from Stripe, no hardcoded price IDs needed
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# AWS / LocalStack (S3 for resume uploads)
# For local dev: run LocalStack and use these test credentials
# For production: use real AWS credentials
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
S3_BUCKET=jobblitz-dev
S3_PREFIX=resumes
